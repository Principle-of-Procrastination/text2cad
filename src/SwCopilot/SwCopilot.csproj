<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">x64</Platform>
    <ProjectGuid>{A1B2C3D4-E5F6-7A8B-9C0D-1E2F3A4B5C6D}</ProjectGuid>
    <OutputType>Library</OutputType>
    <RootNamespace>SwCopilot</RootNamespace>
    <AssemblyName>SwCopilot</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <!-- SolidWorks is 64-bit: the add-in must build x64. -->
    <PlatformTarget>x64</PlatformTarget>
    <!-- We register with regasm /codebase (see deploy/install.bat), not via the
         "Register for COM interop" build option. -->
    <RegisterForComInterop>false</RegisterForComInterop>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|x64' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|x64' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Data" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Xml" />
    <Reference Include="Microsoft.CSharp" />
    <!-- SolidWorks 2025 Primary Interop Assemblies.
         Copy these 3 files from  <SW install>\api\redist\  into  third-party\
         before building. Copy Local = False (SW loads its own PIAs at runtime). -->
    <Reference Include="SolidWorks.Interop.sldworks">
      <HintPath>third-party\SolidWorks.Interop.sldworks.dll</HintPath>
      <Private>False</Private>
      <EmbedInteropTypes>False</EmbedInteropTypes>
    </Reference>
    <Reference Include="SolidWorks.Interop.swconst">
      <HintPath>third-party\SolidWorks.Interop.swconst.dll</HintPath>
      <Private>False</Private>
      <EmbedInteropTypes>False</EmbedInteropTypes>
    </Reference>
    <Reference Include="SolidWorks.Interop.swpublished">
      <HintPath>third-party\SolidWorks.Interop.swpublished.dll</HintPath>
      <Private>False</Private>
      <EmbedInteropTypes>False</EmbedInteropTypes>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="SwAddin.cs" />
    <Compile Include="Routing\CommandTypes.cs" />
    <Compile Include="Routing\CommandRouter.cs" />
    <Compile Include="Planning\PlanBuilder.cs" />
    <Compile Include="Execution\ExecutionResult.cs" />
    <Compile Include="Execution\SwApiHelpers.cs" />
    <Compile Include="Execution\Executor.cs" />
    <Compile Include="UI\CopilotControl.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <!-- OPTIONAL developer convenience: auto-register on each build (needs VS run as admin).
       Left disabled by default; use deploy\install.bat instead.
  <Target Name="AfterBuild" Condition=" '$(Configuration)' == 'Debug' ">
    <Exec Command="&quot;$(WINDIR)\Microsoft.NET\Framework64\v4.0.30319\RegAsm.exe&quot; /codebase &quot;$(TargetPath)&quot;" />
  </Target>
  -->
</Project>
